# Copy to `.env` and fill in.
# `.env` is git-ignored; this template is safe to commit.
#
# Only real secrets live here. Everything else is in settings.yaml.

# Telegram bot token from @BotFather. Required only if
# settings.yaml -> telegram.enabled is true.
TELEGRAM_BOT_TOKEN=

# Optional: override the settings file path (defaults to settings.yaml
# in the current working directory, falling back to settings.example.yaml).
# ARB_SETTINGS_PATH=/etc/arbitrage/settings.yaml
